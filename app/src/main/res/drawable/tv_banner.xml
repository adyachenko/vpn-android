        android:pathData="M80,62 L118,62 L122,74 L122,108 Q122,130 100,138 Q78,130 78,108 Z" />

    <!-- Checkmark inside shield -->
    <path
        android:fillColor="#7AB4FF"
        android:pathData="M86,96 L96,110 L118,84 L112,80 L96,102 L90,92 Z" />

    <!-- App name: block-letter paths forming "SBOXY" on the right side -->
    <!-- S -->
    <path
        android:fillColor="#E6E6E6"
        android:pathData="M155,70 h24 v10 h-18 v8 h16 v10 h-16 v10 h18 v10 h-24 Z" />
