<?xml version="1.0" encoding="utf-8"?>
<!--
  Android TV banner, 320x180 per Leanback guidelines.
  Used by the launcher to represent the app on the TV home screen.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180"
    tools:ignore="VectorRaster">

    <!-- Background -->
    <path
        android:fillColor="#1A1B1E"
        android:pathData="M0,0h320v180h-320z" />

    <!-- Accent bar on the left -->
    <path
        android:fillColor="#7AB4FF"
        android:pathData="M0,0h6v180h-6z" />

    <!-- Shield silhouette (simple geometric, centered vertically, left half) -->
    <path
        android:fillColor="#7AB4FF"
        android:pathData="M70,50 L110,50 L130,70 L130,110 Q130,140 100,150 Q70,140 70,110 Z" />

    <!-- Inner shield highlight -->
