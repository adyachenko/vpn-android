    <!-- O -->
    <path
        android:fillColor="#E6E6E6"
        android:pathData="M217,70 h22 v48 h-22 Z M225,80 v28 h6 v-28 Z" />
    <!-- X -->
    <path
        android:fillColor="#E6E6E6"
        android:pathData="M245,70 h8 l6,10 l6,-10 h8 l-10,24 l10,24 h-8 l-6,-10 l-6,10 h-8 l10,-24 Z" />
    <!-- Y -->
    <path
        android:fillColor="#E6E6E6"
        android:pathData="M275,70 h8 l6,14 l6,-14 h8 l-10,24 v24 h-8 v-24 Z" />

    <!-- Subtitle dot pattern -->
    <path
        android:fillColor="#5A6170"
        android:pathData="M155,130 h4 v4 h-4 Z M163,130 h4 v4 h-4 Z M171,130 h4 v4 h-4 Z M179,130 h4 v4 h-4 Z M187,130 h4 v4 h-4 Z" />
